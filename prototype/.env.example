# Apple Health Coach — environment variables
#
# Copy this file to `.env` and fill in your key.
# `.env` is gitignored and never committed.

# Anthropic Messages API key. If absent, /api/chat falls back to the
# deterministic template generator and the response is flagged with
# usedFallback: true / fallbackReason: "no_api_key".
ANTHROPIC_API_KEY=

# Optional model overrides.
# Coach Generator (default): claude-haiku-4-5-20251001 — fast, cheap, max_tokens 150
# Judge Evaluator (default): claude-opus-4-6           — frontier reasoning for evals
# COACH_MODEL=claude-haiku-4-5-20251001
# JUDGE_MODEL=claude-opus-4-6

# Server port (default 3000)
# PORT=3000
